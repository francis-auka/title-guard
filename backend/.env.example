# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/titleguard?retryWrites=true&w=majority

# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_replace_in_production

# Server port
PORT=5000

# Polygon Amoy Testnet RPC URL (from Alchemy)
ALCHEMY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_api_key_here

# Deployer wallet private key (WITHOUT 0x prefix for some tools)
PRIVATE_KEY=your_wallet_private_key_here

# Deployed TitleGuard contract address (fill after deploying)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Pinata IPFS (optional — for storing files on IPFS)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Email credentials (optional — for sending verification emails)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
